generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  supervisor
  admin
  lider
  capturacion

  @@map("rol_enum")
}

model Usuario {
  id                  Int       @id @default(autoincrement())
  nombreCompleto      String    @map("nombre_completo")
  codigoEmpleado      String    @unique @map("codigo_empleado")
  puesto              String
  plantaId            Int?      @map("planta_id")
  rol                 Rol
  contrasena          String
  correo              String
  isActive            Boolean   @default(true) @map("is_active")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  plant               Plant?    @relation(fields: [plantaId], references: [id])
  refreshTokens       RefreshToken[]
  resetTokens         PasswordResetToken[]
  samplingResults     SamplingResult[]   @relation("SampledBy")
  signedReports       DailyReport[]      @relation("SignedBy")
  publishedReports    DailyReport[]      @relation("PublishedBy")

  @@map("usuarios")
}

model Region {
  id           Int      @id @default(autoincrement())
  name         String
  codigoRegion String?  @unique @map("codigo_region") @db.VarChar
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  plants       Plant[]

  @@map("regions")
}

model Plant {
  id         Int         @id @default(autoincrement())
  name       String
  address    String?
  regionId   Int?        @map("region_id")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  region     Region?     @relation(fields: [regionId], references: [id])
  orders     Order[]
  tablets    Tablet[]
  usuarios   Usuario[]
  orderItems OrderItem[]
  quotations Quotation[]

  @@map("plants")
}

model Tablet {
  id                   Int       @id @default(autoincrement())
  model                String
  serialNumber         String    @unique @map("serial_number")
  alias                String?
  status               String
  plantId              Int?      @map("plant_id")
  currentInspectorName String?   @map("current_inspector_name")
  inspectorAssignedAt  DateTime? @map("inspector_assigned_at")
  lastSeenAt           DateTime? @map("last_seen_at")
  codigoTablet         String    @unique @map("codigo_tablet")
  notes                String?
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  plant                Plant?    @relation(fields: [plantId], references: [id])

  @@map("tablets")
}

model Order {
  id                  Int        @id
  state               String?
  consecutiveNumber   String?    @map("consecutive_number")
  serviceTypeDetail   String?    @map("service_type_detail")
  serviceTypeName     String?    @map("service_type_name")
  piecesPerHour       Decimal?   @map("pieces_per_hour") @db.Decimal
  authorizedHours     Decimal?   @map("authorized_hours") @db.Decimal
  pricePerHour        Decimal?   @map("price_per_hour") @db.Decimal
  language            String?
  userName            String?    @map("user_name")
  regionId            Int?       @map("region_id")
  clientName          String?    @map("client_name")
  clientContactName   String?    @map("client_contact_name")
  clientContactEmail  String?    @map("client_contact_email")
  plantId             Int?       @map("plant_id")
  createdAt           DateTime?  @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime?  @map("updated_at") @db.Timestamptz(6)
  plant               Plant?     @relation(fields: [plantId], references: [id])
  quotations          Quotation[]

  @@map("orders")
}

model Quotation {
  id                     Int         @id
  consecutiveNumber      String?     @map("consecutive_number")
  clientName             String?     @map("client_name")
  clientEmail            String?     @map("client_email")
  status                 String?
  purchaseOrderNumber    String?     @map("purchase_order_number")
  contactEmails          String?     @map("contact_emails")
  orderUserName          String?     @map("order_user_name")
  orderConsecutiveNumber String?     @map("order_consecutive_number")
  regionId               Int?        @map("region_id")
  plantId                Int?        @map("plant_id")
  orderId                Int         @map("order_id")
  createdAt              DateTime?   @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime?   @map("updated_at") @db.Timestamptz(6)
  order                  Order       @relation(fields: [orderId], references: [id])
  plant                  Plant?      @relation(fields: [plantId], references: [id])
  items                  OrderItem[]

  @@map("quotations")
}

model OrderItem {
  id               Int       @id @default(autoincrement())
  quotationId      Int       @map("quotation_id")
  inventory        Decimal?  @db.Decimal
  inventoryDone    Decimal?  @map("inventory_done") @db.Decimal
  partNumber       String?   @map("part_number") @db.VarChar
  partName         String?   @map("part_name") @db.VarChar
  incidents        String?
  plantId          Int?      @map("plant_id")
  createdAt        DateTime? @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime? @map("updated_at") @db.Timestamptz(6)
  quotation        Quotation @relation(fields: [quotationId], references: [id])
  plant            Plant?    @relation(fields: [plantId], references: [id])
  sessions         InspectionSession[]
  dailyReports     DailyReport[]

  @@map("order_items")
}

model InspectionSession {
  id          Int       @id @default(autoincrement()) @map("id_session")
  supervisorId String   @map("id_supervisor")
  tabletId    String    @map("id_tablet")
  orderItemId Int       @map("id_order_item")
  status      String
  fechaInicio DateTime? @map("fecha_inicio")
  fechaFin    DateTime? @map("fecha_fin")
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])

  @@map("inspection_sessions")
}

model DailyReport {
  id              Int                  @id @default(autoincrement())
  orderItemId     Int                  @map("order_item_id")
  shift           String?
  reportDate      DateTime             @map("report_date") @db.Date
  createdAt       DateTime?            @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime?            @map("updated_at") @db.Timestamptz(6)
  status          String               @default("pendiente")
  signedAt        DateTime?            @map("signed_at")
  signedBy        Int?                 @map("signed_by")
  publishedAt     DateTime?            @map("published_at")
  publishedBy     Int?                 @map("published_by")
  orderItem       OrderItem            @relation(fields: [orderItemId], references: [id])
  items           DailyReportItem[]
  operators       DailyReportOperator[]
  samplingResults SamplingResult[]
  signedByUser    Usuario?             @relation("SignedBy", fields: [signedBy], references: [id])
  publishedByUser Usuario?             @relation("PublishedBy", fields: [publishedBy], references: [id])

  @@map("daily_reports")
}

model DailyReportItem {
  id              Int                    @id @default(autoincrement())
  dailyReportId   Int                    @map("daily_report_id")
  totalPieces     Int?                   @map("total_pieces")
  okPieces        Int?                   @map("ok_pieces")
  ngPieces        Int?                   @map("ng_pieces")
  scrapPieces     Int?                   @map("scrap_pieces")
  recoveredPieces Int?                   @map("recovered_pieces")
  dailyReport     DailyReport            @relation(fields: [dailyReportId], references: [id])
  incidents       DailyReportIncident[]

  @@map("daily_report_items")
}

model DailyReportOperator {
  id            Int         @id @default(autoincrement())
  dailyReportId Int         @map("daily_report_id")
  operatorName  String?     @map("operator_name") @db.VarChar
  dailyReport   DailyReport @relation(fields: [dailyReportId], references: [id])

  @@map("daily_report_operators")
}

model DailyReportIncident {
  id               Int             @id @default(autoincrement())
  dailyReportItemId Int            @map("daily_report_item_id")
  incidentName     String?         @map("incident_name") @db.VarChar
  affectedPieces   Int?            @map("affected_pieces")
  dailyReportItem  DailyReportItem @relation(fields: [dailyReportItemId], references: [id])

  @@map("daily_report_incidents")
}

model SamplingResult {
  id            Int         @id @default(autoincrement())
  dailyReportId Int         @map("daily_report_id")
  sampledBy     Int         @map("sampled_by")
  sampledPieces Int         @map("sampled_pieces")
  okPieces      Int         @map("ok_pieces")
  ngPieces      Int         @map("ng_pieces")
  observations  String?
  approved      Boolean     @default(true)
  sampledAt     DateTime    @default(now()) @map("sampled_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  dailyReport   DailyReport @relation(fields: [dailyReportId], references: [id], onDelete: Cascade)
  sampledByUser Usuario     @relation("SampledBy", fields: [sampledBy], references: [id])

  @@map("sampling_results")
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      Usuario   @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      Usuario   @relation(fields: [userId], references: [id])

  @@map("password_reset_tokens")
}
